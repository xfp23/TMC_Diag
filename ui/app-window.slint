import { Button, VerticalBox, HorizontalBox, ComboBox, CheckBox, LineEdit, TextEdit, GroupBox } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "TMC 控制器诊断测试工具";
    min-width: 450px;
    min-height: 750px;
    background: #f5f5f5;
    icon: @image-url("favicon.ico");

    // --- 数据模型 ---
    in-out property <int> diag-status: 0;
    in property <string> test-status: "等待测试";
    property <color> status-color: 
        diag-status == 1 ? #FFA500 : // 橙黄色 (Orange)
        diag-status == 2 ? #0b700b : // 绿色 (Green)
        diag-status == 3 ? #FF0000 : // 红色 (Red)
        #808080;                     // 默认灰色 (Gray)

    in property <bool> OpenDevBtnEnable: true;
    in property <bool> CloseDevBtnEnable: false;
    in property <bool> StartDiagBtnEnable: false;

    in-out property <bool> OpenDevError: false;

    in-out property <int> step-one-status :0;
    in-out property <int> step-two-status :0;
    in-out property <int> step-three-status :0;
    in-out property <int> step-four-status :0;

    property <color> step1-color:
        step-one-status == 1 ? #00FF00 : // 绿色 (Green)
        step-one-status == 2 ? #FF0000 : // 红色 (Red)
        #808080;                     // 默认灰色 (Gray)
    property <color> step2-color:
        step-two-status == 1 ? #00FF00 : // 绿色 (Green)
        step-two-status == 2 ? #FF0000 : // 红色 (Red)
        #808080;                     // 默认灰色 (Gray);
    property <color> step3-color: 
        step-three-status == 1 ? #00FF00 : // 绿色 (Green)
        step-three-status == 2 ? #FF0000 : // 红色 (Red)
        #808080;                     // 默认灰色 (Gray);;
    property <color> step4-color: 
        step-four-status == 1 ? #00FF00 : // 绿色 (Green)
        step-four-status == 2 ? #FF0000 : // 红色 (Red)
        #808080;                     // 默认灰色 (Gray);;

    in-out property <int> selected-can-channel: 0;
    in-out property <int> selected-can-baud: 0;

    // --- 回调函数 ---
    callback connect-clicked();
    callback disconnect-clicked();
    callback start-test-clicked();

    // --- 焦点转发：实现热键的关键 ---
    forward-focus: main-handler;

    main-handler := FocusScope {
        // 键盘事件处理
        key-pressed(event) => {
            if (event.text == Key.Return) {
                if (root.OpenDevError) {
                    root.OpenDevError = false; // 弹窗显示时回车关闭弹窗
                    return accept;
                }
                if (root.StartDiagBtnEnable) {
                    root.start-test-clicked(); // 正常状态回车开始测试
                    return accept;
                }
            }
            return reject;
        }

        // 原有 UI 布局开始
        VerticalBox {
            padding: 20px;
            spacing: 15px;

            // 1. 设备连接配置
            Text { text: "设备连接配置"; font-size: 16px; font-weight: 700; }
            
            GridLayout {
                spacing: 10px;
                Row {
                    VerticalBox { 
                        padding: 0; Text { text: "设备型号:"; }
                        ComboBox { model: ["USBCAN-2E-U"]; current-index: 0; }
                    }
                    VerticalBox { 
                        padding: 0; Text { text: "CAN通道:"; }
                        ComboBox { model: ["通道 1", "通道 2"]; current-index <=> root.selected-can-channel; }
                    }
                }
                Row {
                    VerticalBox { 
                        padding: 0; Text { text: "仲裁波特率:"; }
                        ComboBox { model: ["500K", "250K"]; current-index <=> root.selected-can-baud;}
                    }
                    VerticalBox { 
                        padding: 0; alignment: center;
                        CheckBox { text: "启用 120Ω"; checked: false; }
                    }
                }
            }

            // 2. 连接按钮
            HorizontalBox {
                spacing: 10px;
                Button { 
                    text: "打开设备"; height: 35px;
                    enabled: root.OpenDevBtnEnable;
                    clicked => { root.connect-clicked() }
                }
                Button { 
                    text: "关闭设备"; height: 35px;
                    enabled: root.CloseDevBtnEnable;
                    clicked => { root.disconnect-clicked() }
                }
            }

            // 3. 状态条
            Rectangle {
                height: 50px;
                background: root.status-color;
                border-radius: 5px;
                Text {
                    text: root.test-status;
                    color: white;
                    font-size: 20px;
                    font-weight: 700;
                }
            }

            Rectangle { height: 1px; background: #DDD; }

            // 4. 测试任务列表
            Text { text: "测试任务列表"; font-size: 16px; font-weight: 700; }

            VerticalBox {
                padding: 0; spacing: 5px;
                
                Rectangle {
                    border-width: 1px; border-color: #DDD; border-radius: 5px; background: white;
                    HorizontalBox {
                        Text { text: "步骤 1: 安全解锁 (Seed-Key)"; vertical-alignment: center; }
                        Rectangle { width: 15px; height: 15px; border-radius: 7.5px; background: root.step1-color; }
                    }
                }
                Rectangle {
                    border-width: 1px; border-color: #DDD; border-radius: 5px; background: white;
                    HorizontalBox {
                        Text { text: "步骤 2 & 3: 写入 F1C1 数据"; vertical-alignment: center; }
                        Rectangle { width: 15px; height: 15px; border-radius: 7.5px; background: root.step2-color; }
                    }
                }
                Rectangle {
                    border-width: 1px; border-color: #DDD; border-radius: 5px; background: white;
                    HorizontalBox {
                        Text { text: "步骤 4: 读取并校验 F1C1"; vertical-alignment: center; }
                        Rectangle { width: 15px; height: 15px; border-radius: 7.5px; background: root.step3-color; }
                    }
                }
                Rectangle {
                    border-width: 1px; border-color: #DDD; border-radius: 5px; background: white;
                    HorizontalBox {
                        Text { text: "步骤 5: 读取F180数据"; vertical-alignment: center; }
                        Rectangle { width: 15px; height: 15px; border-radius: 7.5px; background: root.step3-color; }
                    }
                }
            }

            // 5. 开始按钮
            Button {
                text: "开始自动测试";
                height: 45px;
                enabled: root.StartDiagBtnEnable;
                primary: true;
                clicked => { root.start-test-clicked() }
            }

            // 6. 日志
            Text { text: "实时日志:"; font-weight: 700; }
            TextEdit {
                font-family: "Consolas";
                font-size: 11px;
                read-only: true;
            }
        }

        // 弹窗逻辑 (放在主容器内，确保层级正确)
        if (root.OpenDevError) : Rectangle {
            background: #00000080;
            horizontal-stretch: 1;
            vertical-stretch: 1;

            HorizontalBox {
                alignment: center;
                VerticalBox {
                    alignment: center;
                    Rectangle {
                        width: 300px;
                        height: 150px;
                        background: white;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: #ccc;

                        VerticalBox {
                            padding: 15px;
                            spacing: 10px;
                            alignment: center;

                            Text {
                                text: "打开设备失败";
                                color: red;
                                font-size: 16px;
                                horizontal-alignment: center;
                            }

                            Button {
                                text: "确定";
                                clicked => {
                                    root.OpenDevError = false;
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}